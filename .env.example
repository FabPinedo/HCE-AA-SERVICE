# auth-pruebas-auth — Auth Service
# Generated by Jarvis Platform

PORT=
NODE_ENV=development

# Servicio externo de autenticación
EXTERNAL_AUTH_URL=

# JWT
JWT_SECRET=***REPLACE_WITH_SECRET***
JWT_EXPIRES_IN=4h
JWT_REFRESH_SECRET=***REPLACE_WITH_SECRET***
JWT_REFRESH_EXPIRES_IN=7d

# Kafka Audit Logger
KAFKA_BROKER=
KAFKA_TOPIC=platform.logs
